---
interface Props {
  name: string;
  period: string;
  role?: string;
  description: string;
  highlights?: string;
}
const { name, period, role, description, highlights } = Astro.props;
---
<div class="project-item">
  <div class="project-perms">drwxr-xr-x</div>
  <div class="project-meta">
    <div>
      <span class="project-name">{name}</span>
      <span class="period">{period}</span>
    </div>
    <div class="project-desc">{role ? `${role} — ${description}` : description}</div>
    {highlights && <div class="project-desc">→ {highlights}</div>}
    <slot />
  </div>
</div>
