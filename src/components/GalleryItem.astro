---
interface Props {
  src: string;
  alt: string;
  caption?: string;
}
const { src, alt, caption } = Astro.props;
---
<figure class="gallery-item">
  <button class="gallery-link" data-src={src} data-alt={alt} aria-label={`View ${alt}`}>
    <img src={src} alt={alt} loading="lazy" class="gallery-img" />
    <div class="gallery-overlay">
      <span class="gallery-zoom">[VIEW]</span>
    </div>
  </button>
  {caption && <figcaption class="gallery-caption">{caption}</figcaption>}
</figure>
